{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "myscoutee": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "docs",
              "browser": ""
            },
            "browser": "src/main.ts",
            "prerender": false,
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/assets",
              "src/404.html",
              "src/robots.txt",
              "src/manifest.webmanifest",
              "src/app-sw.js",
              {
                "glob": "**/*",
                "input": "keys",
                "output": "keys"
              }
            ],
            "styles": [
              "src/_styles/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.production.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "400kB"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "styles": {
                  "inlineCritical": true
                },
                "fonts": {
                  "inline": true
                }
              }
            },
            "production-demo": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.demo-github.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "400kB"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "styles": {
                  "inlineCritical": true
                },
                "fonts": {
                  "inline": true
                }
              }
            },
            "demo-github": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.demo-github.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "400kB"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "styles": {
                  "inlineCritical": true
                },
                "fonts": {
                  "inline": true
                }
              }
            },
            "development": {
              "outputPath": {
                "base": "dev",
                "browser": ""
              },
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "demo-npm": {
              "outputPath": {
                "base": "dev",
                "browser": ""
              },
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "demo-http": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.demo-http.ts"
                }
              ],
              "outputPath": {
                "base": "dev",
                "browser": ""
              },
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "e2e": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.e2e.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "400kB"
                }
              ],
              "outputHashing": "all",
              "optimization": {
                "styles": {
                  "inlineCritical": true
                },
                "fonts": {
                  "inline": true
                }
              }
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "host": "0.0.0.0",
            "allowedHosts": true
          },
          "configurations": {
            "production": {
              "buildTarget": "myscoutee:build:production"
            },
            "development": {
              "buildTarget": "myscoutee:build:development"
            },
            "demo-npm": {
              "buildTarget": "myscoutee:build:demo-npm"
            },
            "demo-http": {
              "buildTarget": "myscoutee:build:demo-http"
            },
            "e2e": {
              "buildTarget": "myscoutee:build:e2e"
            },
            "demo-github": {
              "buildTarget": "myscoutee:build:demo-github"
            },
            "production-serve": {
              "buildTarget": "myscoutee:build:production"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
