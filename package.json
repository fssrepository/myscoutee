{
  "name": "myscoutee",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "NG_BUILD_MAX_WORKERS=12 ng serve --configuration development",
    "start:pcores": "taskset -c 0-3 env NG_BUILD_MAX_WORKERS=12 ng serve --configuration development",
    "build": "NG_BUILD_MAX_WORKERS=12 ng build --configuration development",
    "build:pcores": "taskset -c 0-3 env NG_BUILD_MAX_WORKERS=12 ng build --configuration development",
    "build:prod": "NG_BUILD_MAX_WORKERS=12 ng build --configuration production",
    "build:prod:pcores": "taskset -c 0-3 env NG_BUILD_MAX_WORKERS=12 ng build --configuration production",
    "build:gh": "NG_BUILD_MAX_WORKERS=12 ng build --configuration production --base-href /myscoutee/",
    "build:gh:pcores": "taskset -c 0-3 env NG_BUILD_MAX_WORKERS=12 ng build --configuration production --base-href /myscoutee/",
    "watch": "NG_BUILD_MAX_WORKERS=12 ng build --watch --configuration development",
    "watch:pcores": "taskset -c 0-3 env NG_BUILD_MAX_WORKERS=12 ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/cdk": "~21.1.2",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "~21.1.2",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/material": "^21.1.2",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
